<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>System Logs - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="row">
      <%- include('admin-sidebar', { currentPage: 'logs' }) %>
      <div class="col-md-9">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">System Logs</h1>
          </div>
          <div class="card-body">
            <p>View system logs and activity.</p>
            <div class="mb-3">
              <label for="logFilter" class="form-label">Filter Logs</label>
              <select class="form-select" id="logFilter">
                <option>All</option>
                <option>Errors</option>
                <option>Warnings</option>
                <option>Info</option>
              </select>
            </div>
            <div class="border p-3" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;">
              <pre>[2026-03-16 10:00:00] INFO: Server started on port 3000
[2026-03-16 10:05:00] INFO: User Admin logged in
[2026-03-16 10:10:00] INFO: User User logged in
[2026-03-16 10:15:00] WARNING: Failed login attempt for unknown user
[2026-03-16 10:20:00] INFO: Admin accessed /admin/users</pre>
            </div>
            <button class="btn btn-primary mt-3">Refresh Logs</button>
            <button class="btn btn-secondary mt-3">Export Logs</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
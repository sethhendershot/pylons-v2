<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PlayTracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.css">
  <script type="text/javascript" charset="utf8" src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.js"></script>
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">PlayTracker</h1>
            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createPlayModal">Add New Play</button>
          </div>
          <div class="card-body">
            <p>Welcome to PlayTracker, <%= user.username %>!</p>
            <p>Track and analyze your plays here.</p>
            <table id="playsTable" class="table table-striped">
              <thead>
                <tr>
                  <th>PLAY #</th>
                  <th>ODK</th>
                  <th>DN</th>
                  <th>DIST</th>
                  <th>HASH</th>
                  <th>YARD LN</th>
                  <th>PLAY TYPE</th>
                  <th>RESULT</th>
                  <th>GN/LS</th>
                  <th>OFF FORM</th>
                  <th>OFF PLAY</th>
                  <th>OFF STR</th>
                  <th>PLAY DIR</th>
                  <th>GAP</th>
                  <th>PASS ZONE</th>
                  <th>DEF FRONT</th>
                  <th>COVERAGE</th>
                  <th>BLITZ</th>
                  <th>QTR</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Create Play Modal -->
  <div class="modal fade" id="createPlayModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Create New Play</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="createPlayForm">
          <div class="modal-body">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY #</label>
                <input type="number" class="form-control" name="playNumber" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">ODK</label>
                <input type="text" class="form-control" name="odk">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DN</label>
                <input type="number" class="form-control" name="dn">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DIST</label>
                <input type="number" class="form-control" name="dist">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">HASH</label>
                <input type="text" class="form-control" name="hash">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">YARD LN</label>
                <input type="number" class="form-control" name="yardLn">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY TYPE</label>
                <input type="text" class="form-control" name="playType">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">RESULT</label>
                <input type="text" class="form-control" name="result">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">GN/LS</label>
                <input type="text" class="form-control" name="gnLs">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF FORM</label>
                <input type="text" class="form-control" name="offForm">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF PLAY</label>
                <input type="text" class="form-control" name="offPlay">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF STR</label>
                <input type="text" class="form-control" name="offStr">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY DIR</label>
                <input type="text" class="form-control" name="playDir">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">GAP</label>
                <input type="text" class="form-control" name="gap">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PASS ZONE</label>
                <input type="text" class="form-control" name="passZone">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DEF FRONT</label>
                <input type="text" class="form-control" name="defFront">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">COVERAGE</label>
                <input type="text" class="form-control" name="coverage">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">BLITZ</label>
                <input type="text" class="form-control" name="blitz">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">QTR</label>
                <input type="number" class="form-control" name="qtr">
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Create Play</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Play Modal -->
  <div class="modal fade" id="editPlayModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Play</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="editPlayForm">
          <input type="hidden" name="id">
          <div class="modal-body">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY #</label>
                <input type="number" class="form-control" name="playNumber" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">ODK</label>
                <input type="text" class="form-control" name="odk">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DN</label>
                <input type="number" class="form-control" name="dn">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DIST</label>
                <input type="number" class="form-control" name="dist">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">HASH</label>
                <input type="text" class="form-control" name="hash">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">YARD LN</label>
                <input type="number" class="form-control" name="yardLn">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY TYPE</label>
                <input type="text" class="form-control" name="playType">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">RESULT</label>
                <input type="text" class="form-control" name="result">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">GN/LS</label>
                <input type="text" class="form-control" name="gnLs">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF FORM</label>
                <input type="text" class="form-control" name="offForm">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF PLAY</label>
                <input type="text" class="form-control" name="offPlay">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">OFF STR</label>
                <input type="text" class="form-control" name="offStr">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PLAY DIR</label>
                <input type="text" class="form-control" name="playDir">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">GAP</label>
                <input type="text" class="form-control" name="gap">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">PASS ZONE</label>
                <input type="text" class="form-control" name="passZone">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">DEF FRONT</label>
                <input type="text" class="form-control" name="defFront">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">COVERAGE</label>
                <input type="text" class="form-control" name="coverage">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">BLITZ</label>
                <input type="text" class="form-control" name="blitz">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">QTR</label>
                <input type="number" class="form-control" name="qtr">
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Update Play</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let table;
    let currentEditId = null;

    $(document).ready(function() {
      table = $('#playsTable').DataTable({
        ajax: '/api/plays',
        columns: [
          { data: 'playNumber' },
          { data: 'odk' },
          { data: 'dn' },
          { data: 'dist' },
          { data: 'hash' },
          { data: 'yardLn' },
          { data: 'playType' },
          { data: 'result' },
          { data: 'gnLs' },
          { data: 'offForm' },
          { data: 'offPlay' },
          { data: 'offStr' },
          { data: 'playDir' },
          { data: 'gap' },
          { data: 'passZone' },
          { data: 'defFront' },
          { data: 'coverage' },
          { data: 'blitz' },
          { data: 'qtr' },
          {
            data: null,
            render: function(data, type, row) {
              return `
                <button class="btn btn-sm btn-primary edit-btn" data-id="${row.id}">Edit</button>
                <button class="btn btn-sm btn-danger delete-btn" data-id="${row.id}">Delete</button>
              `;
            }
          }
        ]
      });

      // Create play
      $('#createPlayForm').on('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        fetch('/api/plays', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(() => {
          $('#createPlayModal').modal('hide');
          table.ajax.reload();
          this.reset();
        });
      });

      // Edit play
      $('#playsTable').on('click', '.edit-btn', function() {
        const id = $(this).data('id');
        // Since we have the row data, we can populate directly
        const row = table.row($(this).closest('tr')).data();
        currentEditId = id;
        Object.keys(row).forEach(key => {
          if (key !== 'id') {
            $(`#editPlayForm [name=${key}]`).val(row[key]);
          }
        });
        $('#editPlayModal').modal('show');
      });

      $('#editPlayForm').on('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        fetch(`/api/plays/${currentEditId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(() => {
          $('#editPlayModal').modal('hide');
          table.ajax.reload();
        });
      });

      // Delete play
      $('#playsTable').on('click', '.delete-btn', function() {
        const id = $(this).data('id');
        if (confirm('Are you sure you want to delete this play?')) {
          fetch(`/api/plays/${id}`, { method: 'DELETE' })
          .then(() => table.ajax.reload());
        }
      });
    });
  </script>
</body>
</html>
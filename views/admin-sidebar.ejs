<div class="col-md-3">
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0"><i class="bi bi-list me-1"></i>Admin Menu</h5>
    </div>
    <div class="list-group list-group-flush">
      <a href="/admin" class="list-group-item list-group-item-action <%= currentPage === 'dashboard' ? 'active' : '' %>">
        <i class="bi bi-house me-1"></i>Dashboard
      </a>
      <a href="/admin/users" class="list-group-item list-group-item-action <%= currentPage === 'users' ? 'active' : '' %>">
        <i class="bi bi-people me-1"></i>Manage Users
      </a>
      <a href="/admin/logs" class="list-group-item list-group-item-action <%= currentPage === 'logs' ? 'active' : '' %>">
        <i class="bi bi-journal-text me-1"></i>View System Logs
      </a>
      <a href="/admin/settings" class="list-group-item list-group-item-action <%= currentPage === 'settings' ? 'active' : '' %>">
        <i class="bi bi-gear me-1"></i>Configure Settings
      </a>
    </div>
  </div>
</div>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="row">
      <%- include('admin-sidebar', { currentPage: 'dashboard' }) %>
      <div class="col-md-9">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Admin Dashboard</h1>
          </div>
          <div class="card-body">
            <h2>Welcome to the Admin Panel, <%= user.username %>!</h2>
            <p>You have administrative privileges.</p>
            <div class="row">
              <div class="col-md-4">
                <div class="card text-center">
                  <div class="card-body">
                    <h5 class="card-title">Users</h5>
                    <p class="card-text">Manage system users</p>
                    <a href="/admin/users" class="btn btn-primary">Manage Users</a>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card text-center">
                  <div class="card-body">
                    <h5 class="card-title">Logs</h5>
                    <p class="card-text">View system logs</p>
                    <a href="/admin/logs" class="btn btn-primary">View Logs</a>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card text-center">
                  <div class="card-body">
                    <h5 class="card-title">Settings</h5>
                    <p class="card-text">Configure system settings</p>
                    <a href="/admin/settings" class="btn btn-primary">Configure</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>